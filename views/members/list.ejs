<!DOCTYPE html>
<html>
<head>
    <title>Members</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .button-group {
            display: flex;
            justify-content: space-between; /* แยกปุ่มซ้าย-ขวา */
            margin-top: 20px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }

        th {
            background-color: #2c3e50;
            color: white;
        }

        button {
            padding: 6px 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .edit-btn {
            background-color: #007bff;
            color: white;
        }

        .delete-btn {
            background-color: #dc3545;
            color: white;
        }

        .back-btn, .add-btn {
            padding: 8px 16px;
            border-radius: 5px;
            border: none;
            cursor: pointer;
        }

        .back-btn {
            background-color: #6c757d;
            color: white;
        }

        .add-btn {
            background-color: #28a745;
            color: white;
        }
    </style>
</head>
<body>
    <h1>ตารางข้อมูลสมาชิก</h1>
    <div class="button-group">
        <button class="back-btn" onclick="window.location.href='/'">กลับไปหน้าหลัก</button>
        <button class="add-btn" onclick="window.location.href='/members/add'">เพิ่มข้อมูลสมาชิก</button>
    </div>

    <table>
        <tr>
            <th>ลำดัล</th>
            <th>ชื่อสมาชิก</th>
            <th>อีเมล</th>
            <th>เบอร์โทร</th>
            <th>การดำเนินการ</th>
        </tr>
        <% members.forEach(member => { %>
        <tr>
            <td><%= member.id %></td>
            <td><%= member.name %></td>
            <td><%= member.email %></td>
            <td><%= member.phone %></td>
            <td>
                <a href="/members/edit/<%= member.id %>">
                    <button class="edit-btn">แก้ไขข้อมูล</button>
                </a>
                &nbsp;&nbsp;
                <!-- ใช้ data-attribute เพื่อป้องกันปัญหาชื่อที่มี ' หรือ " -->
                <button class="delete-btn" 
                        data-id="<%= member.id %>" 
                        data-name="<%= member.name.replace(/"/g,'&quot;') %>">
                    ลบข้อมูล
                </button>
            </td>
        </tr>
        <% }) %>
    </table>

    <script>
        // เพิ่ม event listener ให้ปุ่ม Delete
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const memberId = this.getAttribute('data-id');
                const memberName = this.getAttribute('data-name');
                const confirmed = confirm(`คุณต้องการลบสมาชิก "${memberName}" หรือไม่?`);
                if (confirmed) {
                    window.location.href = `/members/delete/${memberId}`;
                }
            });
        });
    </script>
</body>
</html>
