<!DOCTYPE html>
<html>
<head>
    <title>Borrows</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .button-group {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }

        th {
            background-color: #2c3e50;
            color: white;
        }

        button {
            padding: 6px 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .back-btn, .add-btn, .return-btn {
            padding: 8px 16px;
            border-radius: 5px;
            border: none;
            cursor: pointer;
        }

        .back-btn {
            background-color: #6c757d;
            color: white;
        }

        .add-btn {
            background-color: #28a745;
            color: white;
        }

        .return-btn {
            background-color: #007bff;
            color: white;
        }

        .returned-text {
            color: green;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <h1>ตารางข้อมูลการยืมหนังสือ</h1>
    <div class="button-group">
        <button class="back-btn" onclick="window.location.href='/'">กลับไปหน้าหลัก</button>
        <button class="add-btn" onclick="window.location.href='/borrows/borrow'">เพิ่มข้อมูลการยืม</button>
    </div>

    <table>
        <tr>
            <th>ลำดับ</th>
            <th>ชื่อหนังสือ</th>
            <th>ชื่อสมาชิก</th>
            <th>วันที่ยืมหนังสือ</th>
            <th>วันที่คืนหนังสือ</th>
            <th>การดำเนินการ</th>
        </tr>
        <% borrows.forEach(borrow => { %>
        <tr>
            <td><%= borrow.id %></td>
            <td><%= borrow.title %></td>
            <td><%= borrow.name %></td>
            <td><%= borrow.borrow_date %></td>
            <td class="return-date"><%= borrow.return_date ? borrow.return_date : "ยังไม่ได้คืนหนังสือ" %></td>
            <td class="action-cell">
                <% if (!borrow.return_date) { %>
                    <button class="return-btn" 
                            data-id="<%= borrow.id %>" 
                            data-book="<%= borrow.title.replace(/"/g,'&quot;') %>" 
                            data-member="<%= borrow.name.replace(/"/g,'&quot;') %>">
                        คืนหนังสือ
                    </button>
                <% } else { %>
                    <span class="returned-text">ทำการคืนหนังสือแล้ว</span>
                <% } %>
            </td>
        </tr>
        <% }) %>
    </table>

    <script>
        document.querySelectorAll('.return-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const borrowId = this.dataset.id;
                const bookTitle = this.dataset.book;
                const memberName = this.dataset.member;

                const confirmed = confirm(`คุณต้องการคืนหนังสือ "${bookTitle}" ของสมาชิก "${memberName}" หรือไม่?`);
                if (!confirmed) return;

                // ส่งคำสั่งไป server เพื่ออัปเดต return_date ใน DB
                fetch(`/borrows/return/${borrowId}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            
                            const actionCell = btn.parentElement;
                            actionCell.innerHTML = '<span class="returned-text">ทำการคืนหนังสือแล้ว</span>';

                            // อัปเดตวันที่คืนในตาราง
                            const returnDateCell = actionCell.previousElementSibling;
                            const today = new Date();
                            const yyyy = today.getFullYear();
                            const mm = String(today.getMonth() + 1).padStart(2, '0');
                            const dd = String(today.getDate()).padStart(2, '0');
                            returnDateCell.textContent = `${yyyy}-${mm}-${dd}`;
                        } else {
                            alert('เกิดข้อผิดพลาด ไม่สามารถคืนหนังสือได้');
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
                    });
            });
        });
    </script>
</body>
</html>
